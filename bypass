-- Function to create a tab
local function CreateTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Parent = TabContainer
    btn.Size = UDim2.new(0.2, -5, 1, -10)
    btn.Position = UDim2.new(#tabs * 0.2, 5, 0, 5)
