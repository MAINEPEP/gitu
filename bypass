-- Visual features
MakeToggle(visualTab, "ESP (Box + Name)", function(state)
    _G.ESPEnabled = state
    local espObjects = {}
    
    local function createESP(player)
        if not player.Character then return end
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ESP_Box"
        box.Size = Vector3.new(3, 5, 2)
        box.Color3 = player.TeamColor and player.TeamColor.Color or Color3.fromRGB(255, 0, 0)
        box.AlwaysOnTop = true
        box.ZIndex = 10
        box.Adornee = hrp
        box.Parent = hrp
        
        local nameTag = Instance.new("BillboardGui")
        nameTag.Name = "ESP_Name"
        nameTag.Size = UDim2.new(0, 150, 0, 25)
        nameTag.StudsOffset = Vector3.new(0, 2.5, 0)
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.Text = player.Name
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.BackgroundTransparency = 1
        label.TextStrokeTransparency = 0
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.Font = Enum.Font.Gotham
        label.TextSize = 11
        label.Parent = nameTag
        
        nameTag.Parent = hrp
        
        espObjects[player] = {box, nameTag}
    end
    
    local function removeESP(player)
        if espObjects[player] then
            for _, obj in ipairs(espObjects[player]) do
                if obj then obj:Destroy() end
            end
            espObjects[player] = nil
        end
    end
    
    if state then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                createESP(player)
            end
        end
        
        Players.PlayerAdded:Connect(function(player)
            if _G.ESPEnabled then
                player.CharacterAdded:Connect(function()
                    createESP(player)
                end)
            end
        end)
        
        Players.PlayerRemoving:Connect(function(player)
            removeESP(player)
        end)
    else
        for _, player in pairs(Players:GetPlayers()) do
            removeESP(player)
        end
    end
end)

