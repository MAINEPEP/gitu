        player.Character:MoveTo(hit.Position)
    end
end

-- === TRIGGERBOT ===
local function triggerBot()
    local target = mouse.Target
    if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
        local args = {
            [1] = target.Parent:FindFirstChild("Humanoid")
        }
        game:GetService("ReplicatedStorage"):FindFirstChild("DamageEvent"):FireServer(unpack(args))
    end
end

-- === SILENT AIM ===
local function silentAim()
    local target = getClosestPlayer()
    if target and target.Character then
        local part = target.Character:FindFirstChild(Main.aimbot.part) or target.Character:FindFirstChild("Head")
        if part then
            local cframe = CFrame.new(player.Character.HumanoidRootPart.Position, part.Position)
            player.Character.HumanoidRootPart.CFrame = cframe
        end
    end
end

